<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="PesoTracker"
        android:theme="@style/Theme.PesoTracker"
        android:usesCleartextTraffic="true">
        <!--
          usesCleartextTraffic=true is needed only because the Spring Boot
          backend runs on plain http://10.0.2.2:8080 during local development
          (Android emulator's alias for your machine's localhost). Remove
          this once you deploy the backend behind https.
        -->

        <activity
            android:name=".ui.LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.RegisterActivity" android:exported="false" />
        <activity android:name=".ui.DashboardActivity" android:exported="false" />

    </application>

</manifest>
