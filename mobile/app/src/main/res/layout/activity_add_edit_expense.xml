<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="24dp" android:background="#F0F4F8">

    <TextView android:id="@+id/tvTitle" android:text="Add Expense"
        android:textSize="22sp" android:textStyle="bold" android:textColor="#1F3B57"
        android:layout_marginBottom="20dp"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <TextView android:id="@+id/tvError" android:textColor="#C0392B"
        android:textSize="13sp" android:visibility="gone" android:layout_marginBottom="8dp"
        android:background="#FDF0F0" android:padding="8dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <TextView android:text="Amount (₱)" android:textSize="12sp" android:textColor="#555" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <EditText android:id="@+id/etAmount" android:hint="0.00"
        android:inputType="numberDecimal" android:layout_marginBottom="14dp"
        android:background="@drawable/input_bg"
        android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp"/>
    <TextView android:text="Category" android:textSize="12sp" android:textColor="#555" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <Spinner android:id="@+id/spinnerCategory" android:layout_marginBottom="14dp"
        android:background="@drawable/input_bg" android:padding="8dp"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
    <TextView android:text="Date (YYYY-MM-DD)" android:textSize="12sp" android:textColor="#555" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <EditText android:id="@+id/etDate" android:hint="2026-07-06"
        android:inputType="text" android:layout_marginBottom="14dp"
        android:background="@drawable/input_bg"
        android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp"/>
    <TextView android:text="Note (optional)" android:textSize="12sp" android:textColor="#555" android:textStyle="bold"
        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
    <EditText android:id="@+id/etNote" android:hint="e.g. Lunch at canteen"
        android:inputType="text" android:layout_marginBottom="20dp"
        android:background="@drawable/input_bg"
        android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp"/>
    <Button android:id="@+id/btnSave" android:text="Save Expense"
        android:backgroundTint="#1F3B57" android:textColor="@android:color/white"
        android:layout_width="match_parent" android:layout_height="wrap_content"/>
</LinearLayout>